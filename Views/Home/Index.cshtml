@{
    ViewData["Title"] = "Cuidado com sua mente";
}

<section class="hero scroll-fade">
    <div class="hero-content">
        <h1>Você não está sozinho</h1>
        <p>Encontre apoio emocional e profissionais de saúde mental de forma simples e acolhedora.</p>
        <a href="#support-form" class="btn btn-primary btn-lg">Pedir apoio agora</a>
    </div>
</section>

<section class="section ai-helper scroll-fade">
    <div class="ai-card card shadow-sm">
        <div class="card-body">
            <h2 class="card-title mb-2">Em que posso ajudar?</h2>
            <p class="section-subtitle mb-3">
                Escreva em suas palavras o que está sentindo ou a dúvida que você tem. Uma IA preparada para acolher e orientar irá responder.
            </p>
            <form id="ai-support-form" class="mb-3">
                <label for="aiQuestion" class="form-label">Sua pergunta ou desabafo</label>
                <textarea id="aiQuestion" name="aiQuestion" rows="3" class="form-control" required></textarea>
                <div class="mt-3 d-flex align-items-center gap-3">
                    <button type="submit" class="btn btn-outline-success">
                        Perguntar à IA
                    </button>
                    <span id="ai-support-feedback" class="small text-muted"></span>
                </div>
            </form>
            <div id="ai-response" class="ai-response small text-body-secondary">
                A resposta da IA aparecerá aqui, lembrando sempre que ela não substitui acompanhamento profissional.
            </div>
        </div>
    </div>
</section>

<section class="section scroll-fade" id="professionals">
    <h2>Profissionais recomendados</h2>
    <p class="section-subtitle">Psicólogos, psiquiatras e terapeutas confiáveis para acompanhar você.</p>
    <div id="professionals-list" class="row g-3">
        <div class="col-12 text-muted">Carregando profissionais...</div>
    </div>
</section>

<section class="section scroll-fade" id="support-form">
    <h2>Peça apoio agora</h2>
    <p class="section-subtitle">Descreva brevemente o que você está sentindo. Vamos indicar profissionais que podem ajudar.</p>
    <form id="request-support-form" class="card shadow-sm p-3 support-form">
        <div class="row g-3">
            <div class="col-md-6">
                <label for="userName" class="form-label">Seu nome</label>
                <input id="userName" name="userName" class="form-control" required />
            </div>
            <div class="col-md-6">
                <label for="userEmail" class="form-label">Seu e-mail</label>
                <input id="userEmail" name="userEmail" type="email" class="form-control" required />
            </div>
            <div class="col-md-6">
                <label for="city" class="form-label">Cidade (opcional)</label>
                <input id="city" name="city" class="form-control" />
            </div>
            <div class="col-md-6">
                <label for="topic" class="form-label">Tema principal</label>
                <select id="topic" name="topic" class="form-select" required>
                    <option value="">Selecione...</option>
                    <option>Ansiedade</option>
                    <option>Depressão</option>
                    <option>Burnout / Estresse no trabalho</option>
                    <option>Relacionamentos</option>
                    <option>Luto</option>
                    <option>Autoestima</option>
                    <option>Outros</option>
                </select>
            </div>
            <div class="col-12">
                <label for="message" class="form-label">Conte um pouco mais</label>
                <textarea id="message" name="message" rows="4" class="form-control" required></textarea>
            </div>
        </div>
        <div class="mt-3 d-flex align-items-center gap-3">
            <button type="submit" class="btn btn-success">Enviar pedido de apoio</button>
            <span id="support-feedback" class="small text-muted"></span>
        </div>
        <p class="mt-3 small text-muted">
            Esta plataforma não substitui atendimento de emergência. Em caso de risco imediato à vida, procure o serviço de urgência da sua região.
        </p>
    </form>
</section>

<section class="section scroll-fade" id="recent-requests">
    <h2>Pedidos recentes (anônimos)</h2>
    <p class="section-subtitle">Alguns exemplos de temas que chegam até nós.</p>
    <div id="requests-list" class="list-group small">
        <div class="text-muted">Carregando pedidos...</div>
    </div>
</section>

@section Scripts {
    <script src="~/js/mental-health.js" asp-append-version="true"></script>
}
